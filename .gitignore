# --- Docker ---
docker-compose.override.yml
docker-compose.*.local.yml

# --- Secrets and local configuration (never commit) ---
.env
.env.*
!.env.example
!.env*.example
*.pem
*.pfx
*.p12
*.key
*.jks
secrets.json
**/appsettings.Local.json
**/appsettings.*.local.json
**/appsettings.Development.json
**/appsettings.*.json
!**/appsettings.json
!**/appsettings.Release.json

