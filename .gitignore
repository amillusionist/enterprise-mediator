.vs/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates
*.rsuser
*.userprefs
*.code-workspace
*.DotSettings.user

# VS Code — keep shared workspace settings; ignore local-only files
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# --- .NET / Visual Studio ---
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
