        UILib[REPO-LIB-UICOMP
        emp-ui-component-library]
        style UILib fill:#577494,stroke:#a6c5e3
    end

    subgraph "Application Gateway"
        APIGW[REPO-GW-API
        emp-api-gateway]
        style APIGW fill:#006666,stroke:#99cccc
    end

    subgraph "Backend Services"
        direction TB
